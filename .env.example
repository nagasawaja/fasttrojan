# Required
VULTR_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
DOMAIN=t.example.com

# Required only when the script issues certificates locally with certbot.
# If CERT_FULLCHAIN_FILE and CERT_PRIVATE_KEY_FILE are set, ACME_EMAIL is not used.
ACME_EMAIL=you@example.com

# Vultr instance defaults
# Tokyo      JP
# sgp  Singapore  SG
# icn  Seoul      KR
# syd  Sydney     AU
VULTR_REGION=nrt
VULTR_PLAN=vc2-1c-1gb
VULTR_OS_NAME="Ubuntu 24.04 x64"
VULTR_OS_QUERY="Ubuntu 24.04"
# VULTR_OS_ID=
# VULTR_LABEL=
# VULTR_FIREWALL_GROUP_ID=

# SSH defaults. If VULTR_SSH_KEY_ID is empty, deploy.sh uploads the public key if
# Vultr does not already have the exact same key.
VULTR_SSH_KEY_ID=
VULTR_SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_FILE=~/.ssh/id_ed25519
GENERATE_SSH_KEY=true
SSH_USER=root
SSH_WAIT_INTERVAL=10

# Cloudflare DNS record options. Keep proxied=false for normal Trojan TCP.
CF_TTL=60
CF_PROXIED=false

# Certificate options. Prefer leaving these empty and using DNS-01 certbot cache.
CERT_CACHE_DIR=.certs
CERT_FULLCHAIN_FILE=
CERT_PRIVATE_KEY_FILE=
ACME_STAGING=false
ACME_DNS_PROPAGATION_SECONDS=30
CERT_RENEW_BEFORE_SECONDS=2592000
CERTBOT_IMAGE=certbot/dns-cloudflare:latest

# Trojan and container options
# Leave empty to generate a strong password per deployment.
TROJAN_PASSWORD=
XRAY_IMAGE=ghcr.io/xtls/xray-core:latest
REMOTE_DIR=/opt/trojan
DEPLOY_METHOD=cloud-init
SUBSCRIPTION_PATH=/shuadhTrojan.123
DESTROY_OLD_ON_FORCE_NEW=true
